PRINT_AGENT_CALLBACK_URL=https://your-project.supabase.co/functions/v1/print-agent
PRINT_AGENT_API_KEY=your-print-agent-api-key
POLL_INTERVAL_SECONDS=2
PRINTER_PORT=9100
PRINTER_TIMEOUT_SECONDS=5
MAX_CONCURRENT_JOBS=3
LOG_LEVEL=INFO

# Log file path (for background daemon mode)
# When running in daemon mode (--daemon), logs are written to this file
LOG_FILE=print_agent.log

# Workstation identifier (auto-generated on first run, do not edit manually)
# This unique ID allows the backend to track which workstation printed which job
WORKSTATION_ID=

# Job claiming timeout (seconds)
# Jobs in 'processing' status longer than this are considered stale and will be
# recovered automatically. Set this higher than your expected print duration.
STALE_JOB_TIMEOUT_SECONDS=300
